# TwinAgent AI optional real-AI copilot configuration
#
# The project still works without this file. Without an API key, the copilot
# falls back to deterministic focused answers.
#
# Windows CMD example:
# set TWINAGENT_AI_ENABLED=1
# set OPENAI_API_KEY=your_key_here

TWINAGENT_AI_ENABLED=0
OPENAI_API_KEY=
TWINAGENT_LLM_MODEL=gpt-4o-mini
TWINAGENT_LLM_TEMPERATURE=0.1
