# TwinAgent AI environment template
# Copy this file to .env if you need local environment overrides.

# FastAPI
TWINAGENT_API_HOST=0.0.0.0
TWINAGENT_API_PORT=8000
TWINAGENT_API_RELOAD=0

# Optional OpenAI API usage for AI-assisted copilot mode.
# ChatGPT Plus does not include API credits; this requires separate OpenAI API billing.
OPENAI_API_KEY=

# Optional copilot mode defaults:
# deterministic | auto | ai
TWINAGENT_COPILOT_MODE=deterministic
